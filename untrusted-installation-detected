<!DOCTYPE html>
<html>
<head>
  <title>Security Warning</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <style>
    body {
      margin: 0;
      background: #111;
      color: #ff4444;
      font-family: Arial, sans-serif;
      display: flex;
      height: 100vh;
      justify-content: center;
      align-items: center;
      text-align: center;
    }
    .box {
      max-width: 400px;
      padding: 20px;
    }
    h1 {
